import { Router } from "express";
import { sql, desc } from "drizzle-orm";
import { db } from "@workspace/db";
import { complaintsTable } from "@workspace/db";
import { GetRecentComplaintsQueryParams } from "@workspace/api-zod";

const router = Router();

// GET /dashboard/stats
router.get("/dashboard/stats", async (req, res) => {
  const oneWeekAgo = new Date();
  oneWeekAgo.setDate(oneWeekAgo.getDate() - 7);
  const [stats] = await db.select({
    total:      sql<number>`count(*)::int`,
    pending:    sql<number>`count(*) filter (where status = 'pending')::int`,
    inProgress: sql<number>`count(*) filter (where status = 'in_progress')::int`,
    resolved:   sql<number>`count(*) filter (where status = 'resolved')::int`,
    critical:   sql<number>`count(*) filter (where priority = 'critical')::int`,
    thisWeek:   sql<number>`count(*) filter (where created_at >= ${oneWeekAgo})::int`,
  }).from(complaintsTable);
  res.json(stats ?? { total:0, pending:0, inProgress:0, resolved:0, critical:0, thisWeek:0 });
});

// GET /dashboard/recent
router.get("/dashboard/recent", async (req, res) => {
  const query = GetRecentComplaintsQueryParams.safeParse(req.query);
  const limit = query.success ? (query.data.limit ?? 10) : 10;
  const recent = await db.select().from(complaintsTable)
    .orderBy(desc(complaintsTable.createdAt)).limit(limit);
  res.json(recent);
});

// GET /dashboard/category-breakdown
router.get("/dashboard/category-breakdown", async (req, res) => {
  const breakdown = await db.select({
    category: complaintsTable.category,
    count: sql<number>`count(*)::int`,
  }).from(complaintsTable).groupBy(complaintsTable.category)
    .orderBy(sql`count(*) desc`);
  res.json(breakdown);
});

// GET /dashboard/status-breakdown
router.get("/dashboard/status-breakdown", async (req, res) => {
  const breakdown = await db.select({
    status: complaintsTable.status,
    count: sql<number>`count(*)::int`,
  }).from(complaintsTable).groupBy(complaintsTable.status);
  res.json(breakdown);
});

export default router;
